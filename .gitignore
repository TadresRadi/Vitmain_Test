# ============================================================================
# Root .gitignore — Comprehensive Git Ignore for the entire project
# ============================================================================

# ----------------------------------------------------------------------------
# Secrets & Environments (NEVER commit secrets!)
# ----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.development
.env.monitor
.env.example.local
*.env
!*.env.example

# ----------------------------------------------------------------------------
# OS / System Files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ----------------------------------------------------------------------------
# IDEs and Text Editors
# ----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# ----------------------------------------------------------------------------
# Python Backend
# ----------------------------------------------------------------------------
# Caches and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging / builds
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Django specific
db.sqlite3
db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/logs/

# ----------------------------------------------------------------------------
# Node / Frontend Build & Cache
# ----------------------------------------------------------------------------
node_modules/
/frontend/node_modules/
/frontend/dist/
/frontend/dist-ssr/
/frontend/coverage/
.npm
.eslintcache
.tsbuildinfo
.vite/
.parcel-cache/
.next/

# ----------------------------------------------------------------------------
# Testing & Code Coverage
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage/
*.lcov
.nyc_output/
.tox/
.nox/
.cache/
.ruff_cache/
.mypy_cache/

# ----------------------------------------------------------------------------
# Docker Local Overrides & Volumes
# ----------------------------------------------------------------------------
docker-compose.override.yml
.docker-volumes/

# ----------------------------------------------------------------------------
# Build Packages / ZIP Archives (CI/CD Local Outputs)
# ----------------------------------------------------------------------------
build-package/
*.zip
*.tar.gz
*.tgz
*.log
logs/

# Allow frontend .env files with safe defaults (no secrets)
!frontend/.env.example
!frontend/.env.production
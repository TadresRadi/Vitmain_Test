# ============================================================================
# Root .gitignore — applies to the whole repo
# (supplements backend/.gitignore and frontend/.gitignore)
# ============================================================================

# ---- Secrets / env ----
.env
.env.local
.env.*.local
.env.production
.env.development
# NOTE: .env.example IS tracked (it's the template, no real secrets).

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.installed.cfg
build/
dist/
wheels/
sdist/
var/
parts/

# ---- Node / Frontend build artifacts ----
node_modules/
frontend/node_modules/
frontend/dist/
frontend/coverage/
.parcel-cache/
.vite/
.next/

# ---- Test / coverage caches ----
.pytest_cache/
.coverage
htmlcov/
coverage/
*.lcov
.nyc_output/

# ---- Virtual envs ----
venv/
env/
ENV/
.venv/

# ---- Django media & static ----
backend/media/
backend/staticfiles/

# ---- Logs ----
*.log
logs/

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Docker (local overrides) ----
docker-compose.override.yml

# ---- Misc caches ----
.cache/
.mypy_cache/
.ruff_cache/
.tox/
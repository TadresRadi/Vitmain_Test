# ============================================================================
# Vitmain Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# === REQUIRED (application will not boot without these) ===

# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-to-a-50+-char-random-string

# Debug mode — MUST be false in production
DEBUG=true

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# === DATABASE ===
DB_NAME=vitmain_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# === REDIS ===
REDIS_URL=redis://localhost:6379/1

# === CORS / CSRF ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost
FRONTEND_BASE_URL=http://localhost:5173

# === VODAFONE CASH (required when DEBUG=false) ===
VODAFONE_WEBHOOK_SECRET_TOKEN=local-dev-token-not-real
VODAFONE_RECEIVER_NUMBER=01000000000
VODAFONE_TESTING_PRICE=200.00

# === AI PROVIDERS (optional — features degrade gracefully if missing) ===
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
REPLICATE_API_TOKEN=
STABILITY_API_TOKEN=
DEEPAI_API_TOKEN=
POLLINATIONS_API_KEY=
# Which image provider to use: pollinations, replicate, stability, deepai
IMAGE_PROVIDER=pollinations

# === GOOGLE OAUTH (optional — disables Google login if missing) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === EMAIL (optional — uses console backend in DEBUG mode) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@vitmain.com
SERVER_EMAIL=server@vitmain.com

# === SENTRY (optional — error tracking) ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# === MONITORING (optional) ===
ENABLE_PROMETHEUS=false
USE_JSON_LOGS=false
SLOW_QUERY_THRESHOLD_MS=200

# === SECURITY (production-only) ===
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
JWT_AUTH_COOKIE_SECURE=true

# === LOGGING (optional — defaults to backend/logs/) ===
# LOG_FILE=/app/logs/django.log
# SECURITY_LOG_FILE=/app/logs/security.log
# DB_LOG_FILE=/app/logs/db.log

# === SKIP SETTINGS VALIDATION (emergency only — NOT RECOMMENDED) ===
# SKIP_SETTINGS_VALIDATION=false
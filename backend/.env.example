# Django
SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_CREDENTIALS=true
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0

# Groq - required for AI-generated marketing posts
# Get a key from https://console.groq.com/
GROQ_API_KEY=

# Optional: override the Groq model.
GROQ_MODEL=llama-3.3-70b-versatile

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Seed/support accounts
SEED_ADMIN_EMAIL=admin@vitmain.com
SEED_ADMIN_PASSWORD=
SUPPORT_ACCOUNT_EMAIL=support@vitmain.com
SUPPORT_ACCOUNT_PASSWORD=

# PostgreSQL
DB_NAME=vitmain_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

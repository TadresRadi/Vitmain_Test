# Staging environment — copy to .env.staging and fill in real values.
# This is for testing deployments BEFORE production.

SECRET_KEY=<generate_a_50+_char_random_string>
DEBUG=false
ALLOWED_HOSTS=*

DB_NAME=vitmain_staging
DB_USER=postgres
DB_PASSWORD=<strong_password>
DB_HOST=pgbouncer
DB_PORT=5432

REDIS_URL=redis://redis:6379/1

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
FRONTEND_BASE_URL=http://localhost:8080

VODAFONE_WEBHOOK_SECRET_TOKEN=<random>
VODAFONE_RECEIVER_NUMBER=01000000000

# Use staging/test API keys if available
GROQ_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_TOKEN=
DEEPAI_API_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SENTRY_DSN=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply-staging@vitmain.com
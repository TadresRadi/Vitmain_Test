# Frontend production environment
# This file is committed to the repo — it contains only non-secret defaults.

# API URL — relative path, proxied by Nginx in production
VITE_API_URL=/api

# Google OAuth (set real value in production .env or via build arg)
VITE_GOOGLE_CLIENT_ID=113060445399-6b2b5k5k8caahrit76jg3nus0stmap46.apps.googleusercontent.com

# Feature flags
VITE_ENABLE_CSP=true
VITE_ENABLE_XSS_PROTECTION=true
VITE_ENABLE_OFFLINE_MODE=false